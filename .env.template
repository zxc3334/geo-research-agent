# =============================================================================
# DeepResearch Agent — 多后端 LLM 配置文件
# =============================================================================
# 用法：
#   1. 复制本文件为 .env.local（已被 .gitignore 忽略，不会提交到 Git）
#   2. 填入你的真实 API Key
#   3. 系统启动时自动读取，无需修改源码
# =============================================================================
#
# 【设计原则】
#   .env 只存"连接信息"（API Key、Base URL、Model 名）。
#   采样参数（temperature、max_tokens）由 configs/default.yaml 按模块配置，
#   通过 ModelRouter.create_backend(name, temperature=..., max_tokens=...) 动态覆盖。
# =============================================================================

# ---------------------------------------------------------------------------
# LangSmith 追踪配置（可选）
# ---------------------------------------------------------------------------
# 设为 true 开启追踪，false 则完全禁用（零开销）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_ss_key_here
LANGSMITH_PROJECT=xxx
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com  # 默认，一般不需要改

# ---------------------------------------------------------------------------
# 默认后端选择
# ---------------------------------------------------------------------------
# 可选值: deepseek | vllm | openai | mimo
# 如果未设置，默认使用 vllm
DEFAULT_LLM_BACKEND=deepseek

# ---------------------------------------------------------------------------
# DeepSeek API 配置（仅连接信息）
# ---------------------------------------------------------------------------
DEEPSEEK_API_KEY=your_ss_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# ---------------------------------------------------------------------------
# 本地 vLLM 配置（仅连接信息）
# ---------------------------------------------------------------------------
# VLLM_API_KEY=EMPTY
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---------------------------------------------------------------------------
# OpenAI / 其他 OpenAI 兼容 API（可选）
# ---------------------------------------------------------------------------
# OPENAI_API_KEY=sk-your-openai-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o

# ---------------------------------------------------------------------------
# Xiaomi MiMo 2.5 Pro（OpenAI 兼容）
# ---------------------------------------------------------------------------
MIMO_API_KEY=your_ss_key_here
MIMO_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro

# Web Search 工具配置
# ---------------------------------------------------------------------------
# 后端选择：serpapi | bing | mataso | bocha（默认 serpapi，两者国内均可访问）
SEARCH_BACKEND=bocha

# --- SerpAPI 配置（✅ 国内可访问，每月 100 次免费）---
# 在 https://serpapi.com 注册获取 Key
# SERPAPI_KEY=your_ss_key_here
# SERPAPI_ENDPOINT=https://serpapi.com/search

# --- Bing Search API 配置（✅ 国内稳定，需 Azure 订阅）---
# 在 Azure Portal 创建 "Bing Search v7" 资源获取 Key
#BING_SEARCH_KEY=your_bing_key_here
#BING_SEARCH_ENDPOINT=https://api.bing.microsoft.com/v7.0/search
# ---------------------------------------------------------------------------
# 博查AI 搜索配置（✅ 国内最优，面向 AI Agent 优化）
# ---------------------------------------------------------------------------
BOCHA_API_KEY=your_ss_key_here
BOCHA_API_ENDPOINT=https://api.bochaai.com/v1/web-search

# ---------------------------------------------------------------------------
# 秘塔AI 搜索配置（✅ 中文语义强，支持 research 多轮模式）
# ---------------------------------------------------------------------------
# METASO_API_KEY=your_ss_key_here
# METASO_API_ENDPOINT=https://metaso.cn/api/open/search/v2


# ---------------------------------------------------------------------------
# ArXiv / 论文阅读 工具配置
# ---------------------------------------------------------------------------
# 后端选择：semantic_scholar | arxiv | openalex（默认 openalex，国内可访问）
# 为什么默认 openalex？
#   - semantic_scholar: ✅ 国内可达，覆盖 2 亿+ 论文，免费
#   - arxiv:            ❌ 国内被墙，需 VPN
#   - openalex:         ✅ 国内可达，完全免费，无需 Key
ARXIV_READER_BACKEND=openalex

# --- Semantic Scholar 配置（✅ 国内可达，推荐）---
# 免费申请 Key（可选，无 Key 有 rate limit）：
# https://www.semanticscholar.org/product/api#api-key-form
# SEMANTIC_SCHOLAR_API_KEY=your_ss_key_here
# --- ArXiv 配置（❌ 国内被墙，除非你有 VPN）---
# ARXIV_API_ENDPOINT=http://export.arxiv.org/api/query
# --- OpenAlex 配置（✅ 国内可达，完全免费，无需 Key）---
# 填写邮箱可提高 rate limit，但不填也能用
# https://docs.openalex.org/
OPENALEX_EMAIL=your_email_here


# ---------------------------------------------------------------------------
# Browser 工具配置（✅ 纯 HTTP 抓取，国内可用性取决于目标网站）
# ---------------------------------------------------------------------------
# HTTP 请求超时（秒）
BROWSER_TIMEOUT=15

# 自定义 User-Agent（某些网站需要特定 UA）
# BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36

# ---------------------------------------------------------------------------
# Code Sandbox 工具配置（✅ 纯本地，无网络）
# ---------------------------------------------------------------------------
# 默认执行超时（秒）
CODE_SANDBOX_TIMEOUT=10

# ---------------------------------------------------------------------------
# File Reader 工具配置（✅ 纯本地，无网络）
# ---------------------------------------------------------------------------
# 沙箱根目录：只允许读取此目录下的文件（生产环境强烈建议设置）
FILE_READER_ALLOWED_BASE_DIR=/path/to/allowed/data

# 最大文件大小（字节）
FILE_READER_MAX_FILE_SIZE=10485760

# HuggingFace 国内镜像（避免连接 huggingface.co 超时，同时支持下载新模型）
HF_ENDPOINT=https://hf-mirror.com

